# ---- YouTube Data API v3 (required for ingest) ----
# Google Cloud Console -> APIs & Services -> Credentials -> API key (restrict to YouTube Data API v3)
YOUTUBE_API_KEY=

# ---- Postgres (local docker compose; remapped host port 5436) ----
DATABASE_URL=postgresql://creatorpulse:creatorpulse@localhost:5436/creatorpulse

# ---- Neon (production Postgres) ----
NEON_DATABASE_URL=

# ---- PostHog Cloud (free tier) ----
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ---- Cloudflare R2 (raw archive) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio-creatorpulse-prod

# ---- Upstash Redis (cache, optional) ----
REDIS_URL=
